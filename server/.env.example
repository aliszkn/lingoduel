# LingoDuel — Production secret şablonu
# Bu dosyayı `.env` olarak kopyala ve gerçek değerlerle doldur:
#   cp .env.example .env   (Windows: copy .env.example .env)
# .env ASLA git'e commit edilmez (.gitignore'da).
#
# Güçlü rastgele değer üretmek için (PowerShell):
#   [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))

# Postgres veritabanı şifresi
POSTGRES_PASSWORD=degistir_guclu_rastgele

# Client'ın bağlanırken kullanacağı server key (NakamaService._serverKey ile eşleşmeli)
NAKAMA_SERVER_KEY=degistir_defaultkey_DEGIL

# Session token imza anahtarı (32+ karakter)
NAKAMA_ENCRYPTION_KEY=degistir_en_az_32_karakter_rastgele

# Yönetim konsolu (7351) kimlik bilgileri
NAKAMA_CONSOLE_USER=admin_degistir
NAKAMA_CONSOLE_PASSWORD=degistir_guclu_parola
